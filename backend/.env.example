# Copy this file to .env and fill in your keys.
# Without OPENAI_API_KEY the kiosk runs on the rule-based fallback router
# and uses the browser's speechSynthesis for TTS.

OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o

# TTS (English uses OpenAI; te/hi/ta use the OS-native browser voice).
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Voice options: alloy, echo, fable, onyx, nova, shimmer, sage, coral, ash, ballad, verse
OPENAI_TTS_VOICE=sage
OPENAI_TTS_SPEED=0.92
# Languages routed to the browser's native TTS (skip OpenAI). Comma-separated.
OPENAI_TTS_NON_NATIVE=te,hi,ta

# STT (used only in Auto-language mode for Whisper-based audio detection).
OPENAI_STT_MODEL=whisper-1

# Patient face-recognition match threshold (face-api.js distance, lower = stricter).
PATIENT_MATCH_THRESHOLD=0.55
