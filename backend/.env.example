# Copy this file to .env and fill in your keys.
# Without OPENAI_API_KEY the kiosk runs on the rule-based fallback router
# and uses the browser's speechSynthesis for TTS.

OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o
OPENAI_TTS_MODEL=tts-1
# Voice options: alloy, echo, fable, onyx, nova, shimmer (nova = warm female)
OPENAI_TTS_VOICE=nova
